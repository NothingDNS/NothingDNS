#!/bin/bash
#
# NothingDNS Pre-commit Hook
# Runs CI checks locally before pushing to GitHub
#

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

info() { echo -e "${GREEN}[INFO]${NC} $1"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
error() { echo -e "${RED}[ERROR]${NC} $1"; }
section() { echo -e "\n${CYAN}=== $1 ===${NC}"; }

# Colors for terminal
info() { echo -e "${GREEN}[INFO]${NC} $1"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
error() { echo -e "${RED}[ERROR]${NC} $1"; }

echo ""
echo "=========================================="
echo "  NothingDNS Pre-commit Checks"
echo "=========================================="
echo ""

# Get changed files
CHANGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || echo "")
UNSTAGED_FILES=$(git diff --name-only --diff-filter=ACM 2>/dev/null || echo "")

# Check if there are Go files changed
GO_CHANGED=$(echo "$CHANGED_FILES" | grep -E '\.go$' || true)
WEB_CHANGED=$(echo "$CHANGED_FILES" | grep -E '^web/' || true)
DOCS_CHANGED=$(echo "$CHANGED_FILES" | grep -E '\.(md|yml|yaml)$' || true)

echo "Changed files:"
echo "$CHANGED_FILES" | head -20
echo ""

# Function to run checks
run_go_checks() {
    section "Running Go Checks"

    # go vet
    info "Running go vet..."
    if go vet ./... 2>&1; then
        info "go vet passed"
    else
        error "go vet failed!"
        return 1
    fi

    # go build
    info "Building nothingdns..."
    if go build -o nothingdns ./cmd/nothingdns 2>&1; then
        info "go build passed"
    else
        error "go build failed!"
        return 1
    fi

    # go build dnsctl
    info "Building dnsctl..."
    if go build -o dnsctl ./cmd/dnsctl 2>&1; then
        info "dnsctl build passed"
    else
        error "dnsctl build failed!"
        return 1
    fi

    # Cleanup binaries
    rm -f nothingdns dnsctl 2>/dev/null || true

    return 0
}

run_tests() {
    section "Running Tests"

    info "Running go test (short mode)..."
    if go test ./... -count=1 -short -timeout 120s 2>&1; then
        info "Tests passed"
    else
        error "Tests failed!"
        return 1
    fi

    return 0
}

run_web_checks() {
    section "Running Web Dashboard Checks"

    if [ ! -d "web" ]; then
        warn "web directory not found, skipping web checks"
        return 0
    fi

    cd web

    # Node version check
    local required_node=20
    local node_version=$(node --version 2>/dev/null | cut -d. -f1 | tr -d 'v')
    info "Node.js v${node_version} (npm $(npm --version))"

    if [ "$node_version" -lt "$required_node" ]; then
        error "Node.js $required_node+ required! Found: v$node_version"
        cd ..
        return 1
    fi

    # npm install check
    if [ -f "package.json" ]; then
        info "Ensuring npm dependencies are installed..."
        if [ ! -d "node_modules" ]; then
            npm install 2>&1 || {
                error "npm install failed!"
                cd ..
                return 1
            }
        fi

        # Type check only (skip build in pre-commit - CI does that)
        info "Running TypeScript check (tsc --noEmit)..."
        if npx tsc --noEmit 2>&1; then
            info "TypeScript check passed"
        else
            error "TypeScript check failed!"
            cd ..
            return 1
        fi

        # Lint only
        info "Running ESLint..."
        if npm run lint 2>&1; then
            info "ESLint passed"
        else
            error "ESLint failed!"
            cd ..
            return 1
        fi

        # Skip Vite build in pre-commit - too slow and version-sensitive
        # CI workflow handles the actual build
        info "Skipping Vite build in pre-commit (run by CI)"
    fi

    cd ..
    return 0
}

run_docs_checks() {
    section "Checking Documentation"

    # Check for TODO/FIXME in Go code (only warn)
    TODOS=$(grep -r "TODO\|FIXME\|XXX" --include="*.go" internal/ 2>/dev/null | grep -v "_test.go" || true)
    if [ -n "$TODOS" ]; then
        warn "Found TODOs/FIXMEs in code:"
        echo "$TODOS" | head -5
    fi

    return 0
}

check_dockerfile() {
    section "Checking Dockerfile"

    if [ -f "Dockerfile" ]; then
        info "Dockerfile exists"

        # Basic syntax check (just ensure it has FROM)
        if grep -q "^FROM" Dockerfile; then
            info "Dockerfile syntax looks valid"
        else
            error "Dockerfile missing FROM instruction!"
            return 1
        fi
    fi

    return 0
}

check_workflows() {
    section "Checking GitHub Workflows"

    if [ -d ".github/workflows" ]; then
        info "GitHub workflows directory exists"

        for wf in .github/workflows/*.yml; do
            if [ -f "$wf" ]; then
                name=$(basename "$wf")
                info "Found workflow: $name"

                # Extract key version info
                if [ "$name" = "go.yml" ]; then
                    local go_ver=$(grep "go-version" "$wf" | head -1 | awk -F"'" '{print $2}' | tr -d " '" )
                    [ -z "$go_ver" ] && go_ver=$(grep "go-version" "$wf" | head -1 | awk '{print $2}' | tr -d " '\"" )
                    [ -n "$go_ver" ] && info "  Go version: $go_ver"
                fi

                if [ "$name" = "web.yml" ]; then
                    local node_ver=$(grep "node-version" "$wf" | head -1 | awk -F"'" '{print $2}' | tr -d " '" )
                    [ -z "$node_ver" ] && node_ver=$(grep "node-version" "$wf" | head -1 | awk '{print $2}' | tr -d " '\"" )
                    [ -n "$node_ver" ] && info "  Node version: $node_ver"
                fi
            fi
        done
    fi

    return 0
}

# Main execution
FAILED=0

# Run checks based on changed files
if [ -n "$GO_CHANGED" ]; then
    run_go_checks || FAILED=1
    run_tests || FAILED=1
fi

if [ -n "$WEB_CHANGED" ]; then
    run_web_checks || FAILED=1
fi

if [ -n "$DOCS_CHANGED" ]; then
    run_docs_checks || FAILED=1
fi

# Always run these checks
check_dockerfile || FAILED=1
check_workflows || FAILED=1

# Summary
echo ""
echo "=========================================="
if [ $FAILED -eq 0 ]; then
    echo -e "${GREEN}  All checks passed!${NC}"
    echo "=========================================="
    echo ""
    echo "Safe to push to GitHub!"
    exit 0
else
    echo -e "${RED}  Some checks failed!${NC}"
    echo "=========================================="
    echo ""
    echo -e "${YELLOW}Fix the issues above before pushing.${NC}"
    echo "Or force push with: git push --no-verify"
    exit 1
fi
